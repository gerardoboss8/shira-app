# Supabase — Settings → API en tu proyecto
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="TU_ANON_PUBLIC_KEY"

# Solo para tareas admin del lado servidor (crear usuarios). NO exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="TU_SERVICE_ROLE_KEY"

# Zona horaria del negocio (cálculos de "hoy")
NEXT_PUBLIC_TZ="America/Guatemala"
